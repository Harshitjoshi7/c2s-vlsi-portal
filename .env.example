# C2S VLSI Portal — Environment Variables
# Copy this file to .env and fill in your values

PORT=3000
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard → Settings → Database → Connection String → URI
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

NODE_ENV=development

# Web Push (VAPID) — generate keys by running: node -e "require('web-push').generateVAPIDKeys()" 
# Then add these SAME values to Vercel → Settings → Environment Variables
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=admin@yourdomain.com
